{
  "name": "timeline",
  "version": "1.0.0",
  "description": "Claude Code session timeline extractor monorepo",
  "private": true,
  "packageManager": "pnpm@11.0.3",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "setup": "./scripts/localias-setup.sh",
    "dev": "node scripts/dev.mjs",
    "dev:https": "node scripts/dev.mjs --https",
    "dev:api": "turbo dev --filter=@timeline/api",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "workspaces": [
    "extractor",
    "api",
    "types"
  ]
}
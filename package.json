{
  "name": "@abnersajr/claude-timeline",
  "version": "1.0.2",
  "description": "Claude Code session timeline — extract, visualize, and track costs from your Claude Code sessions",
  "type": "module",
  "packageManager": "pnpm@11.0.3",
  "main": "./dist/cli.js",
  "bin": {
    "claude-timeline": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abnersajr/claude-timeline"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "claude",
    "anthropic",
    "claude-code",
    "timeline",
    "session",
    "extractor",
    "cost-tracker",
    "statusline"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:cli": "node scripts/build.mjs --cli",
    "build:server": "node scripts/build.mjs --server",
    "build:web": "node scripts/build.mjs --web",
    "dev": "node scripts/dev.mjs",
    "dev:api": "turbo dev --filter=claude-timeline-api",
    "prepack": "node scripts/build.mjs",
    "typecheck": "turbo run typecheck --filter=./packages/*",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "better-sqlite3": "11.7.0",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "cors": "2.8.5",
    "express": "5.1.0",
    "minimist": "1.2.8",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@changesets/cli": "^2.31.0",
    "@types/better-sqlite3": "7.6.12",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.6",
    "@types/minimist": "1.2.5",
    "@types/node": "22.10.5",
    "rolldown": "1.0.0",
    "tsdown": "0.22.0",
    "tsx": "4.19.2",
    "turbo": "2",
    "typescript": "5.7.3",
    "vitest": "3.1.1"
  },
  "pnpm": {}
}

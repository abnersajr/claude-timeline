tests {
  test("returns 404", () => {
    expect(res.getStatus()).to.equal(404);
  });

  test("has error message", () => {
    const data = res.getBody();
    expect(data).to.have.property("error");
    expect(data).to.have.property("message");
    expect(data.error).to.equal("not_found");
  });
}